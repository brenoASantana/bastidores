# Variáveis de Ambiente - Exemplo
# Copie este arquivo para .env.local e preencha com seus valores

# Nome da aplicação (visível no navegador)
NEXT_PUBLIC_APP_NAME=BACKROOMS Horror

# URL da aplicação em produção (para links, redirects, etc)
NEXT_PUBLIC_BASE_URL=https://seu-dominio.vercel.app

# Modo de desenvolvimento/produção (auto-configurado pelo Next.js)
# NODE_ENV=production

# Analytics (opcional - descomente se usar)
# NEXT_PUBLIC_GA_ID=UA-XXXXXXXXX-X
